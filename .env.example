# ============================================
# 钉钉机器人 AI 网关 - 环境配置
# ============================================
# 复制此文件为 .env 并填入实际值

# ------------ 钉钉配置 ------------
# 钉钉开放平台 -> 企业内部应用 -> 机器人 -> Stream 模式
DINGTALK_CLIENT_ID=dingxxxxx
DINGTALK_CLIENT_SECRET=your_client_secret_here

# 钉钉卡片模板配置（可选）
# 在钉钉开放平台创建卡片模板后，填写模板 ID
DINGTALK_TEMPLATE_ID=your_template_id_here
# 是否启用卡片消息（启用后会优先使用卡片模板发送消息）
DINGTALK_ENABLE_CARD_MESSAGE=false

# ------------ AI 后端配置 ------------
# 支持 OpenAI 兼容的 API endpoint
# 可以是官方 API、第三方代理、中转站等
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ------------ 服务器配置 ------------
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ------------ Shell 安全配置 ------------
SHELL_TIMEOUT_MS=30000
SHELL_MAX_OUTPUT_BYTES=10485760
# 允许执行的命令（逗号分隔）
SHELL_ALLOWED_COMMANDS=ls,git,cat,grep,find,mkdir,cp,mv,rm,cd,pwd,npm,node,python3,echo,head,tail,wc,sort,uniq,awk,sed,curl,wget,which,ps,kill,df,du,free,top,uptime,uname,whoami,id,chmod,chown,ln,tar,gzip,zip,unzip,diff

# ------------ 文件操作配置 ------------
FILE_MAX_SIZE=10485760
# 允许操作的文件路径（冒号分隔）
FILE_ALLOWED_PATHS=/root/TableBro

# ------------ Claude Code 配置 ------------
CLAUDE_CODE_ENABLED=true
CLAUDE_CODE_PATH=/usr/local/bin/claude